# Resend transactional email
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=

# Default Resend sender (works without a verified domain)
# Replace with antrenamente@your-domain.ro once a domain is verified in Resend
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Manuela Vlasin

# Optional: BCC address that receives a copy of every welcome email
# Leave empty to disable.
RESEND_NOTIFY_BCC=

# Public site URL used in metadata + email links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Opaque plan IDs used as the `?p=` value on /thank-you.
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Server-only (no NEXT_PUBLIC_ prefix). Must match the Stripe Payment Link's success URL.
PLAN_14_ID=
PLAN_7_ID=
