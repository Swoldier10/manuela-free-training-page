# Downstream lead API. Code appends `/api/register-lead` and `/api/update-lead`.
LEAD_API_BASE_URL=https://api.example.com

# Server-only secret sent as `X-API-Key`. Min 16 chars. Never prefix with NEXT_PUBLIC_.
LEAD_API_KEY=

# Public site URL used in metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Opaque IDs used as the `?p=` value on /thank-you to identify the funnel
# branch (upsell = 49 lei recipes, downsell = 39 lei recipes).
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Server-only (no NEXT_PUBLIC_ prefix). Must match each Stripe Payment Link's success URL.
PLAN_UPSELL_ID=
PLAN_DOWNSELL_ID=

# Meta Conversions API. Optional — without these, the server-side mirror of
# Pixel events is skipped (Pixel still fires from the browser). With them,
# every Lead/ViewContent/InitiateCheckout/Purchase fires from both browser
# AND server with a shared event_id, so Meta deduplicates and ad attribution
# survives iOS ATT, Safari ITP, and ad blockers.
#
# Generate the access token at:
#   business.facebook.com → Events Manager → Pixel `1465057615300722`
#     → Settings → Conversions API → "Generate access token"
META_CAPI_ACCESS_TOKEN=
#
# Optional. When set, CAPI events appear under Events Manager → Test Events
# tab instead of production attribution. Use to verify the integration end
# to end ("Browser + Server (Deduplicated)" badge), then UNSET in prod.
# Get the per-session code from the Test Events tab itself.
META_CAPI_TEST_EVENT_CODE=
