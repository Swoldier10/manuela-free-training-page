# Downstream lead webhook. Receives { name, email } on thank-you mount.
LEAD_WEBHOOK_URL=https://bodylab-gskcou81.on-forge.com/api/register-lead

# Public site URL used in metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Opaque plan IDs used as the `?p=` value on /thank-you.
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Server-only (no NEXT_PUBLIC_ prefix). Must match the Stripe Payment Link's success URL.
PLAN_14_ID=
